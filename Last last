//---------------- Internal Helpers ----------------

String getFileName(String path)
{
    int index = path.lastIndexOf('/');

    if(index >= 0)
    {
        return path.substring(index + 1);
    }

    return path;
}



bool fileExists(String path)
{
    return SD.exists(path);
}



//---------------- Game Files ----------------

void clearGameFiles()
{
    gameCount = 0;

    for(uint16_t i = 0; i < MAX_GAME_FILES; i++)
    {
        gameFiles[i].available = false;
    }
}



bool isGameFile(String filename)
{
    filename.toLowerCase();

    if(filename.endsWith(".bin"))
        return true;

    if(filename.endsWith(".nes"))
        return true;

    if(filename.endsWith(".gb"))
        return true;

    if(filename.endsWith(".gbc"))
        return true;


    return false;
}



void scanGames()
{
    clearGameFiles();


    // Built-in Games

    strcpy(
        gameFiles[gameCount].name,
        "MARIO"
    );

    strcpy(
        gameFiles[gameCount].path,
        "BUILTIN"
    );

    gameFiles[gameCount].type =
        GAME_MARIO;

    gameFiles[gameCount].available =
        true;

    gameCount++;



    strcpy(
        gameFiles[gameCount].name,
        "FIFA"
    );

    strcpy(
        gameFiles[gameCount].path,
        "BUILTIN"
    );

    gameFiles[gameCount].type =
        GAME_FIFA;

    gameFiles[gameCount].available =
        true;

    gameCount++;



    strcpy(
        gameFiles[gameCount].name,
        "DOOM"
    );

    strcpy(
        gameFiles[gameCount].path,
        "BUILTIN"
    );

    gameFiles[gameCount].type =
        GAME_DOOM;

    gameFiles[gameCount].available =
        true;

    gameCount++;



    // SD Games

    File folder =
        SD.open(GAMES_FOLDER);


    if(!folder)
        return;


    File file =
        folder.openNextFile();


    while(file && gameCount < MAX_GAME_FILES)
    {

        if(!file.isDirectory())
        {
            String name =
                getFileName(
                    file.name()
                );


            if(isGameFile(name))
            {
                strncpy(
                    gameFiles[gameCount].name,
                    name.c_str(),
                    MAX_FILENAME_LENGTH - 1
                );


                strncpy(
                    gameFiles[gameCount].path,
                    file.name(),
                    MAX_PATH_LENGTH - 1
                );


                gameFiles[gameCount].type =
                    GAME_SD_GAME;


                gameFiles[gameCount].available =
                    true;


                gameCount++;
            }
        }


        file =
            folder.openNextFile();
    }


    folder.close();
}



//---------------- PDF Files ----------------

void clearPDFFiles()
{
    pdfCount = 0;


    for(uint16_t i = 0; i < MAX_GAME_FILES; i++)
    {
        pdfFiles[i].available = false;
    }
}



bool isPDFFile(String filename)
{
    filename.toLowerCase();

    return filename.endsWith(".pdf");
}



void scanPDFs()
{
    clearPDFFiles();


    File folder =
        SD.open(PDF_FOLDER);


    if(!folder)
        return;



    File file =
        folder.openNextFile();



    while(file && pdfCount < MAX_GAME_FILES)
    {

        if(!file.isDirectory())
        {
            String name =
                getFileName(
                    file.name()
                );


            if(isPDFFile(name))
            {
                strncpy(
                    pdfFiles[pdfCount].name,
                    name.c_str(),
                    MAX_FILENAME_LENGTH - 1
                );


                strncpy(
                    pdfFiles[pdfCount].path,
                    file.name(),
                    MAX_PATH_LENGTH - 1
                );


                pdfFiles[pdfCount].pageCount =
                    0;


                pdfFiles[pdfCount].available =
                    true;


                pdfCount++;
            }
        }


        file =
            folder.openNextFile();
    }


    folder.close();
}



//---------------- EEPROM Settings ----------------

void loadSettings()
{
    EEPROM.get(
        0,
        settings
    );


    if(settings.brightness == 0)
    {
        settings.brightness =
            BRIGHTNESS_DEFAULT;

        settings.volume =
            100;

        settings.soundEnabled =
            true;
    }
}



void saveSettings()
{
    EEPROM.put(
        0,
        settings
    );


    EEPROM.commit();
}
