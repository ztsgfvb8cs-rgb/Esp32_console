IndexedFile FileIndex::files[MAX_INDEX_FILES];

uint32_t FileIndex::fileCount = 0;

bool FileIndex::initialized = false;


//====================================================
// BEGIN
//====================================================

bool FileIndex::begin()
{
    if (initialized)
        return true;


    fileCount = 0;

    initialized = true;

    return true;
}


//====================================================
// CLEAR
//====================================================

void FileIndex::clear()
{
    fileCount = 0;
}


//====================================================
// COUNT
//====================================================

uint32_t FileIndex::count()
{
    return fileCount;
}


//====================================================
// GET FILE
//====================================================

IndexedFile FileIndex::get(uint32_t index)
{
    IndexedFile empty;


    empty.path = "";
    empty.name = "";
    empty.extension = "";
    empty.size = 0;
    empty.type = INDEX_ALL;


    if (index >= fileCount)
        return empty;


    return files[index];
}
//====================================================
// SCAN
//====================================================

bool FileIndex::scan(const String& folder,
                     IndexType type)
{
    if (!initialized)
        return false;


    File root = SD.open(folder);


    if (!root)
        return false;


    if (!root.isDirectory())
    {
        root.close();
        return false;
    }


    scanFolder(root, type);


    root.close();


    return true;
}


//====================================================
// FOLDER SCAN
//====================================================

void FileIndex::scanFolder(File folder,
                           IndexType type)
{
    while (true)
    {
        File entry = folder.openNextFile();


        if (!entry)
            break;



        if (entry.isDirectory())
        {
            scanFolder(entry, type);
        }
        else
        {
            String path = entry.path();


            if (accepted(path, type))
            {
                if (fileCount < MAX_INDEX_FILES)
                {
                    files[fileCount].path = path;

                    files[fileCount].name =
                        getNameOnly(path);

                    files[fileCount].extension =
                        getExtensionOnly(path);

                    files[fileCount].size =
                        entry.size();

                    files[fileCount].type =
                        detectType(path);


                    fileCount++;
                }
            }
        }


        entry.close();
    }
}
//====================================================
// TYPE DETECTION
//====================================================

IndexType FileIndex::detectType(const String& path)
{
    String ext = getExtensionOnly(path);


    return extensionToType(ext);
}


//====================================================
// ACCEPT FILE
//====================================================

bool FileIndex::accepted(const String& path,
                         IndexType type)
{
    String ext = getExtensionOnly(path);


    if (!isSupportedFile(ext))
        return false;


    if (type == INDEX_ALL)
        return true;


    return detectType(path) == type;
}


//====================================================
// NAME SEARCH
//====================================================

int FileIndex::findByName(const String& name)
{
    String search = name;

    search.toLowerCase();


    for (uint32_t i = 0; i < fileCount; i++)
    {
        String current = files[i].name;

        current.toLowerCase();


        if (current.indexOf(search) >= 0)
        {
            return i;
        }
    }


    return -1;
}


//====================================================
// TYPE COUNT
//====================================================

uint32_t FileIndex::countType(IndexType type)
{
    uint32_t result = 0;


    for (uint32_t i = 0; i < fileCount; i++)
    {
        if (type == INDEX_ALL ||
            files[i].type == type)
        {
            result++;
        }
    }


    return result;
}
//====================================================
// NAME / EXTENSION HELPERS
//====================================================

String FileIndex::getNameOnly(const String& path)
{
    int slash = path.lastIndexOf('/');


    if (slash < 0)
        return path;


    return path.substring(slash + 1);
}


String FileIndex::getExtensionOnly(const String& path)
{
    String name = getNameOnly(path);


    int dot = name.lastIndexOf('.');


    if (dot < 0)
        return "";


    String ext = name.substring(dot + 1);


    ext.toLowerCase();


    return ext;
}


//====================================================
// SUPPORTED FILES
//====================================================

bool FileIndex::isSupportedFile(const String& extension)
{
    if (extension == "mp3")
        return true;

    if (extension == "wav")
        return true;

    if (extension == "pdf")
        return true;

    if (extension == "bin")
        return true;

    if (extension == "rom")
        return true;

    if (extension == "sav")
        return true;


    return false;
}


//====================================================
// EXTENSION TO TYPE
//====================================================

IndexType FileIndex::extensionToType(const String& extension)
{
    if (extension == "mp3" ||
        extension == "wav")
    {
        return INDEX_MUSIC;
    }


    if (extension == "pdf")
    {
        return INDEX_PDF;
    }


    if (extension == "sav")
    {
        return INDEX_SAVE;
    }


    if (extension == "bin" ||
        extension == "rom")
    {
        return INDEX_GAME;
    }


    return INDEX_ALL;
}
