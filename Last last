#define BROWSER_GAME_MODE 0
#define BROWSER_PDF_MODE  1


static uint8_t browserMode = BROWSER_GAME_MODE;

static uint16_t browserIndex = 0;

static uint16_t browserCount = 0;



//---------------- Initialization ----------------


void initFileBrowser()
{
    browserMode = BROWSER_GAME_MODE;

    browserIndex = 0;

    browserCount = 0;
}



//---------------- Open ----------------


void openGameBrowser()
{
    browserMode = BROWSER_GAME_MODE;

    browserIndex = 0;

    browserCount =
        getGameFileCount();


    currentState =
        STATE_GAME_LIST;


    renderGameBrowser();
}



void openPDFBrowser()
{
    browserMode = BROWSER_PDF_MODE;

    browserIndex = 0;

    browserCount =
        getPDFFileCount();


    currentState =
        STATE_PDF_LIST;


    renderPDFBrowser();
}



//---------------- Close ----------------


void closeBrowser()
{
    currentState =
        STATE_MENU;


    showMainMenu();
}



//---------------- Update ----------------


void updateFileBrowser()
{
    char key =
        getLastKey();



    if(key == '2')
    {
        browserNext();
    }



    else if(key == '8')
    {
        browserPrevious();
    }



    else if(key == '6')
    {
        browserSelect();
    }



    else if(key == '*')
    {
        closeBrowser();
    }



    clearLastKey();
}



//---------------- Navigation ----------------


void browserNext()
{
    if(browserCount == 0)
        return;


    browserIndex++;


    if(browserIndex >= browserCount)
        browserIndex = 0;



    if(browserMode == BROWSER_GAME_MODE)
        renderGameBrowser();

    else
        renderPDFBrowser();
}



void browserPrevious()
{
    if(browserCount == 0)
        return;


    if(browserIndex == 0)
        browserIndex = browserCount - 1;

    else
        browserIndex--;



    if(browserMode == BROWSER_GAME_MODE)
        renderGameBrowser();

    else
        renderPDFBrowser();
}



//---------------- Select ----------------


void browserSelect()
{
    if(browserMode == BROWSER_GAME_MODE)
    {
        startGame(
            GAME_EXTERNAL
        );
    }
    else
    {
        openPDF(
            browserIndex
        );
    }
}



//---------------- Render Game ----------------


void renderGameBrowser()
{
    clearScreen();



    drawText(
        "GAMES",
        110,
        15,
        TFT_CYAN,
        2
    );



    if(browserCount == 0)
    {
        drawText(
            "NO GAME",
            100,
            100,
            TFT_RED,
            2
        );

        updateScreen();

        return;
    }



    drawText(
        getGameFileName(browserIndex),
        20,
        90,
        TFT_YELLOW,
        1
    );



    char info[40];


    snprintf(
        info,
        sizeof(info),
        "%d/%d",
        browserIndex + 1,
        browserCount
    );


    drawText(
        info,
        140,
        150,
        TFT_WHITE,
        1
    );


    updateScreen();
}



//---------------- Render PDF ----------------


void renderPDFBrowser()
{
    clearScreen();



    drawText(
        "PDF FILES",
        90,
        15,
        TFT_GREEN,
        2
    );



    if(browserCount == 0)
    {
        drawText(
            "NO PDF",
            100,
            100,
            TFT_RED,
            2
        );

        updateScreen();

        return;
    }



    drawText(
        getPDFFileName(browserIndex),
        10,
        90,
        TFT_WHITE,
        1
    );



    updateScreen();
}



