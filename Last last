#define PIN_BTN_LEFT    40
#define PIN_BTN_RIGHT   41

// Shoulder Buttons
#define PIN_BTN_LB      7
#define PIN_BTN_RB      21

// Phone Keypad (4x4)
const uint8_t KEYPAD_ROWS[4] = {42, 47, 48, 35};
const uint8_t KEYPAD_COLS[4] = {36, 37, 43, 44};

enum ButtonID
{
    BTN_NONE = 0,
    BTN_UP,
    BTN_DOWN,
    BTN_LEFT,
    BTN_RIGHT,
    BTN_LB,
    BTN_RB
};

