++;\n \n strcpy(gameFiles[2].name, \"DOOM MINI\");\n strcpy(gameFiles[2].path, \"BUILTIN\");\n gameFiles[2].type = GAME_DOOM;\n gameCount++;\n \n Serial.println(\"[OK] Built-in: 3\");\n \n File dir = SD.open(\"/GAMES\");\n if (dir && dir.isDirectory()) {\n File file = dir.openNextFile();\n while (file && gameCount < 50) {\n if (!file.isDirectory()) {\n String fileName = dosya.adı();\n eğer (dosyaUzantısını kontrol et(dosyaAdı, ".bin")) {\n String sadeceAd = dosyaadı çıkar(dosyaAdı);\n eğer (sadeceAd.uzunluk() > 0 && sadeceAd.uzunluk() < 32) {\n strncpy(oyunDosyaları[oyunSayısı].ad, sadeceAd.c_str(),31);\n gameFiles[gameCount].name[31] = '\\0';\n strncpy(gameFiles[gameCount].path, (\"/GAMES/\" + justName).c_str(), 63);\n gameFiles[gameCount].path[63] = '\\0';\n gameFiles[gameCount].type = GAME_FROM_SD;\n Serial.print(\"[SD] \");\n Serial.println(justName);\n gameCount++;\n }\n }\n }\n file = dir.openNextFile();\n }\n dir.close();\n }\n \n Serial.print(\"[OK] Total: \");\n Serial.println(gameCount);\n}\n\n// ========== OYUN BAŞLANGICI ==========\nvoid startSelectedGame() {\n int gameType = gameFiles[currentGameIndex].type;\n \n if (gameType == GAME_MARIO) {\n startMarioGame();\n }\n else if (gameType == GAME_FIFA) {\n startFifaGame();\n }\n else if (gameType == GAME_DOOM) {\n startDoomGame();\n }\n else if (gameType == GAME_FROM_SD) {\n spr.fillSprite(TFT_BLACK);\n spr.setTextColor(TFT_YELLOW, TFT_BLACK);\n spr.setTextSize(2);\n spr.setCursor(30, 100);\n spr.println(\"SD OYUNU\");\n \n spr.setTextColor(TFT_WHITE, TFT_BLACK);\n spr.setTextSize(1);\n spr.setCursor(20, 140);\n spr.println("Henuz uymuyordu.");\n \n spr.pushSprite(0, 0);\n \n unsigned long startTime = millis();\n while (millis() - startTime < 2000) {\n delayMicroseconds(100);\n }\n \n currentGameState = STATE_GAME_LIST;\n showGameList();\n }\n}\n\n// ========== KURULUM ==========\nvoid setup() {\n Serial.begin(115200);\n delay(1000);\n \n Serial.println("\n\n========================================\n");\n 