Audio AudioPlayer::audio;

bool AudioPlayer::playing = false;
bool AudioPlayer::paused = false;

uint8_t AudioPlayer::volume = 12;

String AudioPlayer::fileName = "";

bool AudioPlayer::begin()
{
    audio.setPinout(17, 18, 8);      // BCLK, LRC, DIN
    audio.setVolume(volume);

    playing = false;
    paused = false;

    return true;
}

void AudioPlayer::update()
{
    if (playing && !paused)
    {
        audio.loop();
    }
}

bool AudioPlayer::play(const String& path)
{
    stop();

    if (!SD.exists(path))
        return false;

    fileName = path;

    audio.connecttoFS(SD, path.c_str());

    playing = true;
    paused = false;

    return true;
}

void AudioPlayer::stop()
{
    audio.stopSong();

    playing = false;
    paused = false;

    fileName = "";
}

void AudioPlayer::pause()
{
    if (!playing)
        return;

    audio.pauseResume();

    paused = true;
}

void AudioPlayer::resume()
{
    if (!playing)
        return;

    audio.pauseResume();

    paused = false;
}

bool AudioPlayer::isPlaying()
{
    return playing;
}

bool AudioPlayer::isPaused()
{
    return paused;
}

void AudioPlayer::setVolume(uint8_t newVolume)
{
    if (newVolume > 21)
        newVolume = 21;

    volume = newVolume;

    audio.setVolume(volume);
}

uint8_t AudioPlayer::getVolume()
{
    return volume;
}

String AudioPlayer::currentTrack()
{
    return fileName;
}
