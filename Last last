#include "update_manager.h"

#include <SD.h>
#include <Update.h>

#include "config.h"
#include "system_globals.h"
#include "display.h"


//==================================================
// ESP32 GAME STATION
// UPDATE MANAGER IMPLEMENTATION
//==================================================



static bool updateRunning = false;

static uint8_t updateProgress = 0;



//---------------- Initialization ----------------


void initUpdateManager()
{
    updateRunning = false;

    updateProgress = 0;
}



//---------------- Update Check ----------------


bool checkForUpdate()
{
    if(SD.exists("/UPDATE/update.bin"))
    {
        return true;
    }


    return false;
}



//---------------- Firmware Update ----------------


bool updateFirmware(
    const char* path
)
{

    File updateFile =
        SD.open(path);



    if(!updateFile)
    {
        return false;
    }



    size_t size =
        updateFile.size();



    if(size == 0)
    {
        updateFile.close();

        return false;
    }



    if(!Update.begin(size))
    {
        updateFile.close();

        return false;
    }



    updateRunning = true;



    uint8_t buffer[512];

    size_t written = 0;



    while(updateFile.available())
    {

        size_t read =
            updateFile.read(
                buffer,
                sizeof(buffer)
            );


        if(Update.write(
            buffer,
            read
        ) != read)
        {
            Update.abort();

            updateFile.close();

            updateRunning = false;

            return false;
        }



        written += read;



        updateProgress =
            (written * 100) / size;
    }



    bool result =
        Update.end(true);



    updateFile.close();



    updateRunning = false;



    return result;
}



//---------------- Game Update ----------------


bool updateGameFile(
    const char* path
)
{
    if(!SD.exists(path))
        return false;



    /*
       Oyun güncelleme sistemi:

       Yeni sürümde:
       - versiyon kontrolü
       - checksum
       - yedekleme

       eklenecek.
    */


    return true;
}



//---------------- Screen ----------------


void showUpdateScreen()
{
    clearScreen();


    drawText(
        "SYSTEM UPDATE",
        60,
        30,
        TFT_CYAN,
        2
    );


    char buffer[30];


    snprintf(
        buffer,
        sizeof(buffer),
        "%d%%",
        updateProgress
    );


    drawText(
        buffer,
        140,
        100,
        TFT_YELLOW,
        2
    );


    updateScreen();
}



//---------------- Process ----------------


void processUpdate()
{
    if(checkForUpdate())
    {
        showUpdateScreen();


        updateFirmware(
            "/UPDATE/update.bin"
        );
    }
}
