    return currentSelection;
}
//====================================================
// INPUT UPDATE
//====================================================

void MenuManager::updateInput()
{
    InputManager::update();

    TouchManager::update();


    if (InputManager::up())
    {
        if (currentSelection > 0)
        {
            currentSelection--;
        }
    }


    if (InputManager::down())
    {
        currentSelection++;
    }


    if (InputManager::confirm())
    {
        switch (currentScreen)
        {
            case MENU_HOME:
                break;

            case MENU_GAMES:
                break;

            case MENU_BUILTIN_GAMES:
                break;

            case MENU_MUSIC:
                break;

            case MENU_PDF:
                break;

            case MENU_SETTINGS:
                break;

            case MENU_WIFI:
                break;

            case MENU_FILE_MANAGER:
                break;

            case MENU_POWER:
                break;
        }
    }


    if (InputManager::back())
    {
        back();
    }


    if (TouchManager::touched())
    {
        TouchPoint point = TouchManager::point();

        (void)point;

        // Dokunmatik menü seçimi
        // ileride burada işlenecek.
    }
}
