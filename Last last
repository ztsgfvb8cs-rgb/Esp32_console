//====================================================
// PATH FUNCTIONS
//====================================================

String StorageManager::joinPath(const String& first,
                                const String& second)
{
    String result = first;


    if (!result.endsWith("/"))
        result += "/";


    if (second.startsWith("/"))
        result += second.substring(1);
    else
        result += second;


    return normalizePath(result);
}
String StorageManager::normalizePath(const String& path)
{
    String result = path;


    if (result.length() == 0)
        return "/";


    result.replace("\\", "/");


    result = removeExtraSlash(result);


    if (!result.startsWith("/"))
        result = "/" + result;


    if (result.length() > 1 && result.endsWith("/"))
        result.remove(result.length() - 1);


    return result;
}


