;\n }\n }\n \n if (mario.y > 240.0f) {\n mario.lives--;\n if (mario.lives <= 0) {\n mario.running = false;\n currentEngine = ENGINE_IDLE;\n currentGameState = STATE_GAME_LIST;\n return;\n }\n mario.x = 150.0f;\n mario.y = 200.0f;\n }\n \n if (millis() - mario.timeout > GAME_TIMEOUT) {\n mario.running = false;\n currentEngine = ENGINE_IDLE;\n currentGameState = STATE_GAME_LIST;\n return;\n }\n \n mario.score = (millis() - mario.startTime) / 100;\n \n // ✅ RENDER: Sprite-based\n spr.fillSprite(TFT_BLACK);\n spr.fillRect(0, 220, 320, 20, TFT_GREEN);\n \n for (int i = 0; i < 3; i++) {\n spr.fillRect(mario.enemy_x[i], mario.enemy_y[i],16, 16, TFT_RED);\n }\n \n spr.fillRect((int)mario.x, (int)mario.y, 16, 16, TFT_YELLOW);\n \n spr.setTextColor(TFT_WHITE, TFT_BLACK);\n spr.setTextSize(1);\n spr.setCursor(10, 5);\n spr.print("Skor: ");\n spr.println(mario.score);\n spr.setCursor(200, 5);\n spr.print("Can: ");\n spr.println(mario.lives);\n spr.setCursor(260, 5);\n spr.print("FPS: ");\n spr.println((int)frameStats_fps);\n \n spr.pushSprite(0, 0);\n}\n",
