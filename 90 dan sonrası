#ifndef PROCEDURAL_MAP_GENERATOR_H
#define PROCEDURAL_MAP_GENERATOR_H

#include <Arduino.h>

//====================================================
// MAP MODE
//====================================================

enum MapMode
{
    MAP_MODE_SURF = 0,
    MAP_MODE_PARKOUR
};

//====================================================
// PLATFORM
//====================================================

struct MapPlatform
{
    int16_t x;

    int16_t y;

    uint16_t width;

    uint16_t height;

    bool checkpoint;

    bool moving;

    bool breakable;

    uint8_t type;
};

//====================================================
// LIMITS
//====================================================

#define MAP_MAX_PLATFORMS     128

//====================================================
// CLASS
//====================================================

class ProceduralMapGenerator
{

public:

    static bool begin();

    static void generate(
        uint32_t seed,
        MapMode mode
    );

    static void clear();

    static void update();

    static void reset();

    static uint16_t platformCount();

    static const MapPlatform&
    platform(uint16_t index);

    static uint32_t seed();

    static MapMode mode();

private:

    static void generateSurf();

    static void generateParkour();

    static void generateCheckpoint(
        uint16_t index
    );

    static int16_t randomHeight(
        int16_t previous
    );

private:

    static bool initialized;

    static uint32_t currentSeed;

    static MapMode currentMode;

    static uint16_t totalPlatforms;

    static MapPlatform platforms[
        MAP_MAX_PLATFORMS
    ];

};

#endif
//====================================================
// SURF GENERATION
//====================================================

void ProceduralMapGenerator::generateSurf()
{
    int16_t currentX = 0;

    int16_t currentY = 120;

    for(uint16_t i=0;
        i<MAP_MAX_PLATFORMS;
        i++)
    {
        MapPlatform &p = platforms[i];

        p.x = currentX;

        p.y = currentY;

        p.width =
        random(48,96);

        p.height =
        random(8,16);

        p.type = 0;

        p.breakable = false;

        p.moving = false;

        p.checkpoint = false;

        if(i>0 && i%20==0)
            generateCheckpoint(i);

        currentX +=
        random(40,72);

        currentY =
        randomHeight(currentY);
    }

    totalPlatforms =
    MAP_MAX_PLATFORMS;
}

//====================================================
// PARKOUR GENERATION
//====================================================

void ProceduralMapGenerator::generateParkour()
{
    int16_t currentX = 0;

    int16_t currentY = 140;

    for(uint16_t i=0;
        i<MAP_MAX_PLATFORMS;
        i++)
    {
        MapPlatform &p =
        platforms[i];

        p.x = currentX;

        p.y = currentY;

        p.width =
        random(24,56);

        p.height = 8;

        p.type = 1;

        p.breakable =
        random(0,100)<12;

        p.moving =
        random(0,100)<18;

        p.checkpoint =
        false;

        if(i>0 && i%15==0)
            generateCheckpoint(i);

        currentX +=
        random(36,88);

        currentY =
        randomHeight(currentY);
    }

    totalPlatforms =
    MAP_MAX_PLATFORMS;
}

//====================================================
// CHECKPOINT
//====================================================

void ProceduralMapGenerator::
generateCheckpoint(
    uint16_t index
)
{
    if(index>=MAP_MAX_PLATFORMS)
        return;

    platforms[index]
    .checkpoint = true;
}

//====================================================
// RANDOM HEIGHT
//====================================================

int16_t
ProceduralMapGenerator::
randomHeight(
    int16_t previous
)
{
    int16_t value =
    previous +
    random(-35,36);

    if(value<24)
        value=24;

    if(value>210)
        value=210;

    return value;
}
//====================================================
// UPDATE
//====================================================

void ProceduralMapGenerator::update()
{
    if(!initialized)
        return;

    for(uint16_t i=0;
        i<totalPlatforms;
        i++)
    {
        if(!platforms[i].moving)
            continue;

        //------------------------------------------------
        // Hareketli platformlar
        //------------------------------------------------

        float wave =
        sin(
            millis() * 0.002f +
            (float)i
        );

        platforms[i].y +=
        (int16_t)(wave * 0.8f);
    }
}

//====================================================
// RESET
//====================================================

void ProceduralMapGenerator::reset()
{
    clear();

    currentSeed = 0;

    currentMode = MAP_MODE_SURF;
}

//====================================================
// PLATFORM COUNT
//====================================================

uint16_t
ProceduralMapGenerator::platformCount()
{
    return totalPlatforms;
}

//====================================================
// PLATFORM
//====================================================

const MapPlatform&
ProceduralMapGenerator::platform(
    uint16_t index
)
{
    return platforms[index];
}

//====================================================
// SEED
//====================================================

uint32_t
ProceduralMapGenerator::seed()
{
    return currentSeed;
}

//====================================================
// MODE
//====================================================

MapMode
ProceduralMapGenerator::mode()
{
    return currentMode;
}
