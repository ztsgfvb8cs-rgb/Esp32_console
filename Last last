struct Player
{
    float x;
    float y;
    int score;
    int health;
};


static Player player;



void initGameEngine()
{
    player.x = 160;
    player.y = 120;
    player.score = 0;
    player.health = 100;
}



//---------------- Engine Update ----------------


void updateGameEngine()
{
    if(currentState != STATE_PLAYING)
        return;


    char key =
        getLastKey();


    handleGameInput(
        key
    );


    switch(currentEngine)
    {

        case ENGINE_MARIO:

            updateMario();

            break;


        case ENGINE_FIFA:

            updateFifa();

            break;


        case ENGINE_DOOM:

            updateDoom();

            break;


        case ENGINE_EXTERNAL:

            updateExternalGame();

            break;


        default:

            break;
    }


    clearLastKey();
}



//---------------- Start Game ----------------


void startGame(
    GameType type
)
{
    currentState =
        STATE_PLAYING;


    player.x = 160;
    player.y = 120;

    player.score = 0;

    player.health = 100;


    switch(type)
    {
        case GAME_MARIO:

            currentEngine =
                ENGINE_MARIO;

            break;


        case GAME_FIFA:

            currentEngine =
                ENGINE_FIFA;

            break;


        case GAME_DOOM:

            currentEngine =
                ENGINE_DOOM;

            break;


        default:

            currentEngine =
                ENGINE_EXTERNAL;

            break;
    }
}



//---------------- Stop Game ----------------


void stopGame()
{
    currentEngine =
        ENGINE_NONE;


    currentState =
        STATE_GAME_LIST;


    showGameList();
}



//---------------- Game Input ----------------


void handleGameInput(
    char key
)
{
    if(key == '*')
    {
        stopGame();

        return;
    }


    if(key == '4')
        player.x -= 5;


    if(key == '6')
        player.x += 5;


    if(key == '2')
        player.y -= 5;


    if(key == '8')
        player.y += 5;



    player.x =
        constrain(
            player.x,
            0,
            SCREEN_WIDTH - 10
        );


    player.y =
        constrain(
            player.y,
            0,
            SCREEN_HEIGHT - 20
        );
}



//---------------- Mario ----------------


void updateMario()
{
    clearScreen();


    sprite.fillRect(
        player.x,
        player.y,
        16,
        16,
        TFT_YELLOW
    );


    drawGameHUD();


    updateScreen();
}



//---------------- FIFA ----------------


void updateFifa()
{
    clearScreen();


    sprite.drawCircle(
        SCREEN_WIDTH / 2,
        SCREEN_HEIGHT / 2,
        40,
        TFT_WHITE
    );


    sprite.fillCircle(
        player.x,
        player.y,
        8,
        TFT_GREEN
    );


    drawGameHUD();


    updateScreen();
}



//---------------- DOOM ----------------


void updateDoom()
{
    clearScreen();


    sprite.fillCircle(
        player.x,
        player.y,
        8,
        TFT_RED
    );


    sprite.drawLine(
        SCREEN_WIDTH / 2,
        SCREEN_HEIGHT / 2,
        player.x,
        player.y,
        TFT_WHITE
    );


    drawGameHUD();


    updateScreen();
}



//---------------- External Game ----------------


void updateExternalGame()
{
    clearScreen();


    drawText(
        "EXTERNAL GAME",
        60,
        100,
        TFT_CYAN,
        2
    );


    drawGameHUD();


    updateScreen();
}



//---------------- HUD ----------------


void drawGameHUD()
{
    char buffer[32];


    snprintf(
        buffer,
        sizeof(buffer),
        "SCORE:%d",
        player.score
    );


    drawText(
        buffer,
        5,
        5,
        TFT_WHITE,
        1
    );



    snprintf(
        buffer,
        sizeof(buffer),
        "HP:%d",
        player.health
    );


    drawText(
        buffer,
        250,
        5,
        TFT_WHITE,
        1
    );
}
