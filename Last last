//====================================================

void MenuManager::open(MenuScreen screen)
{
    currentScreen = screen;

    currentSelection = 0;
}


//====================================================
// BACK
//====================================================

void MenuManager::back()
{
    if (currentScreen != MENU_HOME)
    {
        open(MENU_HOME);
    }
}


