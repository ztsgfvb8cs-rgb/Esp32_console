//==================================================
// ESP32 GAME STATION
// FILE MANAGER IMPLEMENTATION
//==================================================



static GameFile internalGames[MAX_GAME_FILES];

static PDFFile internalPDFs[MAX_GAME_FILES];


static uint16_t internalGameCount = 0;

static uint16_t internalPDFCount = 0;



//---------------- Initialization ----------------


void initFileManager()
{
    internalGameCount = 0;

    internalPDFCount = 0;
}



//---------------- Game Scan ----------------


void scanGameDirectory()
{
    internalGameCount = 0;



    File dir =
        SD.open(GAMES_FOLDER);



    if(!dir)
        return;



    File file =
        dir.openNextFile();



    while(file && internalGameCount < MAX_GAME_FILES)
    {

        if(!file.isDirectory())
        {

            String name =
                String(file.name());


            if(name.endsWith(".bin") ||
               name.endsWith(".game"))
            {

                strncpy(
                    internalGames[internalGameCount].name,
                    name.c_str(),
                    MAX_FILENAME_LENGTH - 1
                );


                strncpy(
                    internalGames[internalGameCount].path,
                    file.name(),
                    MAX_PATH_LENGTH - 1
                );


                internalGames[internalGameCount].type =
                    GAME_EXTERNAL;


                internalGameCount++;
            }
        }


        file =
            dir.openNextFile();
    }



    dir.close();
}



//---------------- PDF Scan ----------------


void scanPDFDirectory()
{
    internalPDFCount = 0;



    File dir =
        SD.open(PDF_FOLDER);



    if(!dir)
        return;



    File file =
        dir.openNextFile();



    while(file && internalPDFCount < MAX_GAME_FILES)
    {

        if(!file.isDirectory())
        {

            String name =
                String(file.name());


            if(name.endsWith(".pdf") ||
               name.endsWith(".PDF"))
            {

                strncpy(
                    internalPDFs[internalPDFCount].name,
                    name.c_str(),
                    MAX_FILENAME_LENGTH - 1
                );


                strncpy(
                    internalPDFs[internalPDFCount].path,
                    file.name(),
                    MAX_PATH_LENGTH - 1
                );


                internalPDFCount++;
            }
        }


        file =
            dir.openNextFile();
    }



    dir.close();
}



//---------------- Full Scan ----------------


void scanAllFiles()
{
    scanGameDirectory();

    scanPDFDirectory();
}



//---------------- Game Access ----------------


uint16_t getGameFileCount()
{
    return internalGameCount;
}



const char* getGameFileName(
    uint16_t index
)
{
    if(index >= internalGameCount)
        return "";


    return internalGames[index].name;
}



const char* getGameFilePath(
    uint16_t index
)
{
    if(index >= internalGameCount)
        return "";


    return internalGames[index].path;
}



//---------------- PDF Access ----------------


uint16_t getPDFFileCount()
{
    return internalPDFCount;
}



const char* getPDFFileName(
    uint16_t index
)
{
    if(index >= internalPDFCount)
        return "";


    return internalPDFs[index].name;
}



const char* getPDFFilePath(
    uint16_t index
)
{
    if(index >= internalPDFCount)
        return "";


    return internalPDFs[index].path;
}



//---------------- File Operations ----------------


bool fileExists(
    const char* path
)
{
    return SD.exists(path);
}



bool deleteFile(
    const char* path
)
{
    if(!SD.exists(path))
        return false;


    return SD.remove(path);
}
