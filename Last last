{
    static const char keypad[4][4] =
    {
        {'1','2','3','A'},
        {'4','5','6','B'},
        {'7','8','9','C'},
        {'*','0','#','D'}
    };


    for(int row = 0; row < 4; row++)
    {
        digitalWrite(
            ROW_PINS[row],
            LOW
        );


        for(int col = 0; col < 4; col++)
        {
            if(digitalRead(COL_PINS[col]) == LOW)
            {
                unsigned long now =
                    millis();


                if(now - lastKeyTime < KEY_DEBOUNCE_TIME)
                {
                    digitalWrite(
                        ROW_PINS[row],
                        HIGH
                    );

                    return '\0';
                }


                lastKeyTime = now;


                delay(10);


                if(digitalRead(COL_PINS[col]) == LOW)
                {
                    lastKey =
                        keypad[row][col];


                    digitalWrite(
                        ROW_PINS[row],
                        HIGH
                    );


                    return lastKey;
                }
            }
        }


        digitalWrite(
            ROW_PINS[row],
            HIGH
        );
    }


    return '\0';
}



//---------------- Input Status ----------------

bool isKeyAvailable()
{
    return lastKey != '\0';
}



void updateInput()
{
    char key =
        getKey();


    if(key != '\0')
    {
        lastKey = key;
    }
}



char getLastKey()
{
    return lastKey;
}



void clearLastKey()
{
    lastKey = '\0';
}
