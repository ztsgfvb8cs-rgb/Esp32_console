//====================================================
// ANIMATION TYPES
//====================================================

enum AnimationType
{
    ANIMATION_NONE = 0,

    ANIMATION_IDLE,

    ANIMATION_DRAW,

    ANIMATION_INSPECT,

    ANIMATION_SLASH_1,

    ANIMATION_SLASH_2,

    ANIMATION_STAB
};

//====================================================
// KNIFE TYPES
//====================================================

enum KnifeType
{
    KNIFE_CLASSIC = 0,

    KNIFE_KARAMBIT,

    KNIFE_BUTTERFLY,

    KNIFE_KATANA,

    KNIFE_SHADOW_DAGGERS
};

//====================================================
// FRAME
//====================================================

struct AnimationFrame
{
    int16_t x;

    int16_t y;

    int16_t rotation;

    uint16_t duration;
};

//====================================================
// STATE
//====================================================

struct AnimationState
{
    AnimationType type;

    uint8_t frame;

    uint8_t totalFrames;

    bool playing;

    bool loop;

    uint32_t timer;
};

//====================================================
// MANAGER
//====================================================

class AnimationManager
{

public:

    static bool begin();

    static void update();

    static void play(AnimationType type);

    static void stop();

    static void reset();

    static bool playing();

    static AnimationType current();

    static void setKnife(KnifeType knife);

    static KnifeType knife();

    static const AnimationFrame&
    frame();

private:

    static void updateFrame();

    static void loadAnimation(
        AnimationType type
    );

private:

    static bool initialized;

    static KnifeType currentKnife;

    static AnimationState state;

    static AnimationFrame frames[32];

};

#endif
