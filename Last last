//---------------- Initialization ----------------

void initHardware()
{
    enableBoost();

    initDisplay();

    initSDCard();

    initKeypad();

    initBattery();

    initBuzzer();

    initEEPROM();
}


//---------------- Display ----------------

void initDisplay()
{
    pinMode(TFT_BACKLIGHT_PIN, OUTPUT);

    ledcAttachPin(TFT_BACKLIGHT_PIN, 0);
    ledcSetup(0, 5000, 8);

    ledcWrite(0, BRIGHTNESS_DEFAULT);

    tft.init();

    tft.setRotation(1);

    tft.fillScreen(TFT_BLACK);

    sprite.createSprite(
        SCREEN_WIDTH,
        SCREEN_HEIGHT
    );
}


void setBacklight(uint8_t value)
{
    value = constrain(value, 0, 255);

    ledcWrite(0, value);
}


//---------------- SD Card ----------------

void initSDCard()
{
    SPI.begin(
        SD_SCK_PIN,
        SD_MISO_PIN,
        SD_MOSI_PIN,
        SD_CS_PIN
    );

    SD.begin(SD_CS_PIN);
}


//---------------- Keypad ----------------

void initKeypad()
{
    for(int i = 0; i < 4; i++)
    {
        pinMode(
            ROW_PINS[i],
            OUTPUT
        );

        digitalWrite(
            ROW_PINS[i],
            HIGH
        );
    }


    for(int i = 0; i < 4; i++)
    {
        pinMode(
            COL_PINS[i],
            INPUT_PULLUP
        );
    }
}


char readKeypad()
{
    static const char keys[4][4] =
    {
        {'1','2','3','A'},
        {'4','5','6','B'},
        {'7','8','9','C'},
        {'*','0','#','D'}
    };


    for(int row = 0; row < 4; row++)
    {
        digitalWrite(
            ROW_PINS[row],
            LOW
        );


        for(int col = 0; col < 4; col++)
        {
            if(digitalRead(COL_PINS[col]) == LOW)
            {
                delay(20);

                if(digitalRead(COL_PINS[col]) == LOW)
                {
                    digitalWrite(
                        ROW_PINS[row],
                        HIGH
                    );

                    return keys[row][col];
                }
            }
        }


        digitalWrite(
            ROW_PINS[row],
            HIGH
        );
    }


    return '\0';
}


bool keyPressed(char key)
{
    return readKeypad() == key;
}



//---------------- Battery ----------------

void initBattery()
{
    analogReadResolution(12);

    analogSetAttenuation(
        ADC_11db
    );
}


float readBatteryVoltage()
{
    uint32_t total = 0;


    for(int i = 0; i < 8; i++)
    {
        total += analogRead(BATTERY_ADC_PIN);
    }


    float average =
        total / 8.0f;


    return
    (average / ADC_RESOLUTION)
    *
    ADC_REFERENCE
    *
    BATTERY_DIVIDER;
}



uint8_t calculateBatteryPercent(float voltage)
{
    float percent =
    ((voltage - BATTERY_MIN_VOLTAGE)
    /
    (BATTERY_MAX_VOLTAGE - BATTERY_MIN_VOLTAGE))
    *
    100.0f;


    if(percent < 0)
        percent = 0;


    if(percent > 100)
        percent = 100;


    return (uint8_t)percent;
}



void updateBattery()
{
    float voltage =
        readBatteryVoltage();


    battery.voltage =
        voltage;


    battery.percent =
        calculateBatteryPercent(voltage);
}



//---------------- Buzzer ----------------

void initBuzzer()
{
    pinMode(
        BUZZER_PIN,
        OUTPUT
    );

    digitalWrite(
        BUZZER_PIN,
        LOW
    );


    ledcAttachPin(
        BUZZER_PIN,
        1
    );

    ledcSetup(
        1,
        DEFAULT_BEEP_FREQ,
        8
    );
}



void beep(
    uint16_t frequency,
    uint16_t duration
)
{
    ledcWriteTone(
        1,
        frequency
    );

    delay(duration);

    ledcWriteTone(
        1,
        0
    );
}



//---------------- EEPROM ----------------

void initEEPROM()
{
    EEPROM.begin(
        EEPROM_SIZE
    );
}



//---------------- Boost ----------------

void enableBoost()
{
    pinMode(
        BOOST_ENABLE_PIN,
        OUTPUT
    );

    digitalWrite(
        BOOST_ENABLE_PIN,
        HIGH
    );
}



void disableBoost()
{
    digitalWrite(
        BOOST_ENABLE_PIN,
        LOW
    );
}
