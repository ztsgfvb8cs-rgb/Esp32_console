//==========================================
// HAPTIC MANAGER
// IMPLEMENTATION
//==========================================

bool HapticManager::active = false;
unsigned long HapticManager::startTime = 0;
unsigned long HapticManager::duration = 0;

void HapticManager::begin()
{
    pinMode(PIN_HAPTIC, OUTPUT);
    digitalWrite(PIN_HAPTIC, LOW);
}

void HapticManager::update()
{
    if (active)
    {
        if (millis() - startTime >= duration)
        {
            stop();
        }
    }
}

void HapticManager::vibrate(uint16_t durationMs)
{
    duration = durationMs;
    startTime = millis();
    active = true;

    digitalWrite(PIN_HAPTIC, HIGH);
}

void HapticManager::success()
{
    vibrate(120);
}

void HapticManager::error()
{
    vibrate(300);
}

void HapticManager::warning()
{
    vibrate(180);
}

void HapticManager::click()
{
    vibrate(40);
}

void HapticManager::stop()
{
    digitalWrite(PIN_HAPTIC, LOW);
    active = false;
}

bool HapticManager::isRunning()
{
    return active;
}
