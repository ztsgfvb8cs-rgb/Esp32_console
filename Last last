void clearFileIndex()
{
    fileCount = 0;


    memset(
        fileList,
        0,
        sizeof(fileList)
    );
}



//---------------- Add File ----------------


static void addFile(
    const char* name,
    const char* path,
    FileType type,
    uint32_t size
)
{

    if(fileCount >= MAX_INDEX_FILES)
        return;



    strncpy(
        fileList[fileCount].name,
        name,
        sizeof(fileList[fileCount].name)-1
    );


    strncpy(
        fileList[fileCount].path,
        path,
        sizeof(fileList[fileCount].path)-1
    );


    fileList[fileCount].type =
        type;


    fileList[fileCount].size =
        size;



    fileCount++;
}



//---------------- Scan System ----------------


void scanAllFiles()
{
    clearFileIndex();


    scanGames();

    scanPDFs();

    scanMedia();
}



//---------------- Games ----------------


void scanGames()
{

    File dir =
        SD.open(
            GAMES_FOLDER
        );


    if(!dir)
        return;



    File file =
        dir.openNextFile();



    while(file &&
          fileCount < MAX_INDEX_FILES)
    {

        if(!file.isDirectory())
        {

            addFile(
                file.name(),
                file.name(),
                FILE_GAME,
                file.size()
            );

        }


        file =
            dir.openNextFile();
    }


    dir.close();
}



//---------------- PDF ----------------


void scanPDFs()
{

    File dir =
        SD.open(
            PDF_FOLDER
        );


    if(!dir)
        return;



    File file =
        dir.openNextFile();



    while(file &&
          fileCount < MAX_INDEX_FILES)
    {

        if(!file.isDirectory())
        {

            String name =
                file.name();



            if(name.endsWith(".pdf") ||
               name.endsWith(".PDF"))
            {

                addFile(
                    file.name(),
                    file.name(),
                    FILE_PDF,
                    file.size()
                );
            }
        }



        file =
            dir.openNextFile();
    }


    dir.close();
}



