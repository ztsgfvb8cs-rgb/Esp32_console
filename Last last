    int index
)
{

    if(index < 0 ||
       index >= fileCount)
    {
        return nullptr;
    }


    return &fileList[index];
}



//---------------- Search ----------------


int searchFiles(
    const char* text
)
{

    int count = 0;



    for(int i = 0;
        i < fileCount;
        i++)
    {

        if(strstr(
            fileList[i].name,
            text
        ))
        {
            count++;
        }

    }



    return count;
}
