#include "save_system.h"

#include <EEPROM.h>

#include "config.h"


//==================================================
// ESP32 GAME STATION
// SAVE SYSTEM IMPLEMENTATION
//==================================================



#define SAVE_START_ADDRESS 64



struct SaveData
{
    uint32_t score;

    uint16_t level;

    uint8_t gameID;

    uint8_t checksum;
};



static SaveData saveData;



//---------------- Initialization ----------------


void initSaveSystem()
{
    EEPROM.get(
        SAVE_START_ADDRESS,
        saveData
    );



    if(saveData.checksum !=
       (
        saveData.gameID ^
        (saveData.level & 0xFF)
       ))
    {
        saveData.score = 0;

        saveData.level = 1;

        saveData.gameID = 0;

        updateChecksum();
    }
}



//---------------- Checksum ----------------


static void updateChecksum()
{
    saveData.checksum =
        saveData.gameID ^
        (saveData.level & 0xFF);
}



//---------------- Save ----------------


bool saveGameData(
    uint8_t gameID
)
{
    saveData.gameID =
        gameID;


    updateChecksum();



    EEPROM.put(
        SAVE_START_ADDRESS,
        saveData
    );


    return EEPROM.commit();
}



//---------------- Load ----------------


bool loadGameData(
    uint8_t gameID
)
{
    EEPROM.get(
        SAVE_START_ADDRESS,
        saveData
    );


    if(saveData.gameID != gameID)
        return false;



    return true;
}



//---------------- Clear ----------------


void clearSaveData()
{
    saveData.score = 0;

    saveData.level = 1;

    saveData.gameID = 0;


    updateChecksum();



    EEPROM.put(
        SAVE_START_ADDRESS,
        saveData
    );


    EEPROM.commit();
}



//---------------- Score ----------------


void setPlayerScore(
    uint32_t score
)
{
    saveData.score =
        score;
}



uint32_t getPlayerScore()
{
    return saveData.score;
}



//---------------- Level ----------------


void setPlayerLevel(
    uint16_t level
)
{
    saveData.level =
        level;
}



uint16_t getPlayerLevel()
{
    return saveData.level;
}



//---------------- Settings Backup ----------------


void backupSettings()
{
    EEPROM.put(
        128,
        saveData
    );

    EEPROM.commit();
}



void restoreSettings()
{
    EEPROM.get(
        128,
        saveData
    );
}
