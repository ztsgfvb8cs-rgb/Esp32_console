//====================================================
// STATIC DEFINITIONS
//====================================================

EngineState GameEngine::currentState =
    ENGINE_IDLE;


EngineType GameEngine::currentType =
    ENGINE_NONE;


GameInfo GameEngine::activeGame =
{
    "",
    "",
    GAME_UNKNOWN,
    0
};


bool GameEngine::initialized = false;


//====================================================
// BEGIN
//====================================================

bool GameEngine::begin()
{
    if (initialized)
        return true;


    currentState = ENGINE_IDLE;

    currentType = ENGINE_NONE;


    initialized = true;


    return true;
}


//====================================================
// UPDATE
//====================================================

void GameEngine::update()
{
    if (!initialized)
        return;


    if (currentState != ENGINE_RUNNING)
        return;


    // Burada ileride:
    // - GB Emulator
    // - NES Emulator
    // - Doom
    // - Dahili oyunlar
    // kendi update() fonksiyonlarını çağıracak.
}
//====================================================
// LAUNCH GAME
//====================================================

bool GameEngine::launch(uint32_t gameIndex)
{
    if (!initialized)
        return false;


    stop();


    activeGame = GameManager::get(gameIndex);


    if (activeGame.path.length() == 0)
        return false;


    currentType = detectEngine(activeGame);


    bool result = false;


    switch (currentType)
    {
        case ENGINE_GB:
            result = launchGB(activeGame);
            break;


        case ENGINE_NES:
            result = launchNES(activeGame);
            break;


        case ENGINE_BUILTIN:
            result = launchBuiltin(activeGame);
            break;


        default:
            result = false;
            break;
    }


    if (result)
    {
        currentState = ENGINE_RUNNING;
    }
    else
    {
        currentState = ENGINE_IDLE;

        currentType = ENGINE_NONE;

        activeGame.name = "";
        activeGame.path = "";
        activeGame.type = GAME_UNKNOWN;
        activeGame.size = 0;
    }


    return result;
}


//====================================================
// STOP
//====================================================

void GameEngine::stop()
{
    currentState = ENGINE_STOPPED;

    currentType = ENGINE_NONE;


    activeGame.name = "";

    activeGame.path = "";

    activeGame.type = GAME_UNKNOWN;

    activeGame.size = 0;
}

//====================================================
// PAUSE
//====================================================

void GameEngine::pause()
{
    if (!initialized)
        return;


    if (currentState != ENGINE_RUNNING)
        return;


    currentState = ENGINE_PAUSED;
}


//====================================================
// RESUME
//====================================================

void GameEngine::resume()
{
    if (!initialized)
        return;


    if (currentState != ENGINE_PAUSED)
        return;


    currentState = ENGINE_RUNNING;
}


//====================================================
// STATE
//====================================================

EngineState GameEngine::state()
{
    return currentState;
}


//====================================================
// TYPE
//====================================================

EngineType GameEngine::type()
{
    return currentType;
}


//====================================================
// RUNNING
//====================================================

bool GameEngine::running()
{
    return currentState == ENGINE_RUNNING;
}


//====================================================
// CURRENT GAME
//====================================================

GameInfo GameEngine::currentGame()
{
    return activeGame;
}
//====================================================
// ENGINE DETECTION
//====================================================

EngineType GameEngine::detectEngine(const GameInfo& game)
{
    String path = game.path;

    path.toLowerCase();


    if (path.endsWith(".gb") ||
        path.endsWith(".gbc"))
    {
        return ENGINE_GB;
    }


    if (path.endsWith(".nes"))
    {
        return ENGINE_NES;
    }


    return ENGINE_BUILTIN;
}


