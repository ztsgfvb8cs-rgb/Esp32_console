//====================================================

bool AudioManager::play(const String& path)
{
    if (!initialized)
        return false;


    if (!openFile(path))
        return false;


    currentPath = path;

    currentMode = AUDIO_PLAY;


    return true;
}


//====================================================
// OPEN FILE
//====================================================

bool AudioManager::openFile(const String& path)
{
    if (!StorageManager::exists(path))
        return false;


    return true;
}


//====================================================
// STOP
//====================================================

void AudioManager::stop()
{
    currentMode = AUDIO_STOP;

    currentPath = "";
}
//====================================================
// PAUSE
//====================================================

void AudioManager::pause()
{
    if (currentMode == AUDIO_PLAY)
    {
        currentMode = AUDIO_PAUSE;
    }
}


//====================================================
// RESUME
//====================================================

void AudioManager::resume()
{
    if (currentMode == AUDIO_PAUSE)
    {
        currentMode = AUDIO_PLAY;
    }
}


//====================================================
// VOLUME
//====================================================

void AudioManager::setVolume(uint8_t volume)
