#define MAX_SEARCH_LENGTH 32
#define MAX_RESULTS 50



static char searchText[MAX_SEARCH_LENGTH];

static const char* results[MAX_RESULTS];


static int resultCount = 0;

static SearchType currentType =
    SEARCH_GAMES;


static int selectedResult = 0;



//---------------- Initialization ----------------


void initSearchManager()
{
    clearSearch();

    resultCount = 0;

    selectedResult = 0;
}



//---------------- Start Search ----------------


void startSearch(
    SearchType type
)
{
    currentType = type;

    clearSearch();

    resultCount = 0;
}



//---------------- Text Control ----------------


void addSearchCharacter(
    char key
)
{

    int len =
        strlen(searchText);



    if(len >= MAX_SEARCH_LENGTH - 1)
        return;



    searchText[len] = key;

    searchText[len + 1] = '\0';



    updateSearch();
}



void removeSearchCharacter()
{
    int len =
        strlen(searchText);



    if(len > 0)
    {
        searchText[len - 1] = '\0';
    }


    updateSearch();
}



void clearSearch()
{
    memset(
        searchText,
        0,
        sizeof(searchText)
    );
}



//---------------- Search Engine ----------------


void updateSearch()
{
    resultCount = 0;


    /*
       Arama motoru temel sürümü.

       Sonraki geliştirmede:

       - oyun index sistemi
       - Türkçe karakter desteği
       - otomatik tamamlama
       - SD tarama hızlandırma

       eklenecek.
    */


    if(strlen(searchText) == 0)
        return;



    if(currentType == SEARCH_GAMES)
    {

        if(strstr(
            "MARIO",
            searchText
        ))
        {
            results[resultCount++] =
                "MARIO PLATFORM";
        }



        if(strstr(
            "DOOM",
            searchText
        ))
        {
            results[resultCount++] =
                "DOOM MINI";
        }



        if(strstr(
            "FIFA",
            searchText
        ))
        {
            results[resultCount++] =
                "FIFA SOCCER";
        }

    }



    else if(currentType == SEARCH_PDF)
    {

        if(SD.exists("/PDF"))
        {
            results[resultCount++] =
                "PDF DOSYALARI";
        }

    }
}



//---------------- Results ----------------


int getSearchResultCount()
{
    return resultCount;
}



const char* getSearchResult(
    int index
)
{
    if(index < 0 ||
       index >= resultCount)
    {
        return "";
    }


    return results[index];
}



void selectSearchResult(
    int index
)
{
    if(index >= 0 &&
       index < resultCount)
    {
        selectedResult = index;
    }
}



//---------------- Get Current ----------------


const char* getSearchText()
{
    return searchText;
}



SearchType getSearchType()
{
    return currentType;
}
