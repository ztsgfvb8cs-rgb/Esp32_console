#define TFT_RST  12



//====================================================
// STATIC DEFINITIONS
//====================================================

Adafruit_ILI9341 DisplayManager::display(
    TFT_CS,
    TFT_DC,
    TFT_RST
);


ScreenMode DisplayManager::activeScreen =
    SCREEN_HOME;


uint8_t DisplayManager::brightness = 100;


bool DisplayManager::initialized = false;



//====================================================
// BEGIN
//====================================================

bool DisplayManager::begin()
{
    if (initialized)
        return true;


    SPI.begin();


    display.begin();


    display.setRotation(1);


    display.fillScreen(ILI9341_BLACK);


    initialized = true;


    drawHome();


    return true;
}
//====================================================
// CLEAR
//====================================================

void DisplayManager::clear()
{
    if (!initialized)
        return;


    display.fillScreen(ILI9341_BLACK);
}



//====================================================
// PRINT TEXT
//====================================================

void DisplayManager::printText(String text,
                               int x,
                               int y,
                               uint16_t color,
                               uint8_t size)
{
    if (!initialized)
        return;


    display.setTextColor(color);

    display.setTextSize(size);

    display.setCursor(x, y);


    display.print(text);
}



//====================================================
// SCREEN SELECT
//====================================================

void DisplayManager::showScreen(ScreenMode mode)
{
    if (!initialized)
        return;


    activeScreen = mode;


    clear();


    switch(mode)
    {
        case SCREEN_HOME:
            drawHome();
            break;


        case SCREEN_GAME:
            drawGame();
            break;


        case SCREEN_MUSIC:
            drawMusic();
            break;


        case SCREEN_PDF:
            drawPDF();
            break;


        case SCREEN_SETTINGS:
            drawSettings();
            break;
    }
}



//====================================================
// CURRENT SCREEN
//====================================================

ScreenMode DisplayManager::currentScreen()
{
    return activeScreen;
}
