#include "display.h"


//==================================================
// ESP32 GAME STATION
// THEME MANAGER IMPLEMENTATION
//==================================================



static ThemeType currentTheme =
    THEME_DEFAULT;



static uint16_t backgroundColor =
    TFT_BLACK;


static uint16_t textColor =
    TFT_WHITE;


static uint16_t accentColor =
    TFT_CYAN;



//---------------- Initialization ----------------


void initThemeManager()
{
    loadTheme();

    applyTheme();
}



//---------------- Theme Control ----------------


void setTheme(
    ThemeType theme
)
{
    currentTheme =
        theme;


    applyTheme();

    saveTheme();
}



ThemeType getCurrentTheme()
{
    return currentTheme;
}



//---------------- Colors ----------------


uint16_t getBackgroundColor()
{
    return backgroundColor;
}



uint16_t getTextColor()
{
    return textColor;
}



uint16_t getAccentColor()
{
    return accentColor;
}



//---------------- Apply Theme ----------------


void applyTheme()
{

    switch(currentTheme)
    {

        case THEME_DARK:

            backgroundColor =
                TFT_BLACK;

            textColor =
                TFT_WHITE;

            accentColor =
                TFT_BLUE;

            break;



        case THEME_GREEN:

            backgroundColor =
                TFT_BLACK;

            textColor =
                TFT_WHITE;

            accentColor =
                TFT_GREEN;

            break;



        case THEME_BLUE:

            backgroundColor =
                TFT_NAVY;

            textColor =
                TFT_WHITE;

            accentColor =
                TFT_CYAN;

            break;



        case THEME_CUSTOM:

            backgroundColor =
                TFT_DARKGREY;

            textColor =
                TFT_WHITE;

            accentColor =
                TFT_YELLOW;

            break;



        default:

            backgroundColor =
                TFT_BLACK;

            textColor =
                TFT_WHITE;

            accentColor =
                TFT_CYAN;

            break;
    }
}



//---------------- Save ----------------


void saveTheme()
{
    uint8_t value =
        (uint8_t)currentTheme;


    EEPROM.put(
        20,
        value
    );


    EEPROM.commit();
}



//---------------- Load ----------------


void loadTheme()
{
    uint8_t value;


    EEPROM.get(
        20,
        value
    );



    if(value <= THEME_CUSTOM)
    {
        currentTheme =
            (ThemeType)value;
    }
    else
    {
        currentTheme =
            THEME_DEFAULT;
    }
}
