#include "input_manager.h"

//==========================================
// INPUT MANAGER
// IMPLEMENTATION
//==========================================

static bool buttonState[7];

static const char keypadMap[4][4] =
{
    {'1','2','3','A'},
    {'4','5','6','B'},
    {'7','8','9','C'},
    {'*','0','#','D'}
};

void InputManager::begin()
{
    pinMode(PIN_BTN_UP, INPUT_PULLUP);
    pinMode(PIN_BTN_DOWN, INPUT_PULLUP);
    pinMode(PIN_BTN_LEFT, INPUT_PULLUP);
    pinMode(PIN_BTN_RIGHT, INPUT_PULLUP);

    pinMode(PIN_BTN_LB, INPUT_PULLUP);
    pinMode(PIN_BTN_RB, INPUT_PULLUP);

    for (uint8_t i = 0; i < 4; i++)
    {
        pinMode(KEYPAD_ROWS[i], OUTPUT);
        digitalWrite(KEYPAD_ROWS[i], HIGH);
    }

    for (uint8_t i = 0; i < 4; i++)
    {
        pinMode(KEYPAD_COLS[i], INPUT_PULLUP);
    }

    for (uint8_t i = 0; i < 7; i++)
    {
        buttonState[i] = false;
    }
}

void InputManager::update()
{
    buttonState[BTN_UP] = !digitalRead(PIN_BTN_UP);
    buttonState[BTN_DOWN] = !digitalRead(PIN_BTN_DOWN);
    buttonState[BTN_LEFT] = !digitalRead(PIN_BTN_LEFT);
    buttonState[BTN_RIGHT] = !digitalRead(PIN_BTN_RIGHT);

    buttonState[BTN_LB] = !digitalRead(PIN_BTN_LB);
    buttonState[BTN_RB] = !digitalRead(PIN_BTN_RB);
}

bool InputManager::pressed(ButtonID button)
{
    if (button <= BTN_NONE || button > BTN_RB)
        return false;

    return buttonState[button];
}

char InputManager::readKeypad()
{
    return scanMatrix();
}

char InputManager::scanMatrix()
{
    for (uint8_t row = 0; row < 4; row++)
    {
        digitalWrite(KEYPAD_ROWS[row], LOW);

        delayMicroseconds(5);

        for (uint8_t col = 0; col < 4; col++)
        {
            if (digitalRead(KEYPAD_COLS[col]) == LOW)
            {
                digitalWrite(KEYPAD_ROWS[row], HIGH);
                return keypadMap[row][col];
            }
        }

        digitalWrite(KEYPAD_ROWS[row], HIGH);
    }

    return '\0';
}
