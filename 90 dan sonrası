#ifndef PHYSICS_MANAGER_H
#define PHYSICS_MANAGER_H

#include <Arduino.h>

//====================================================
// PHYSICS MODES
//====================================================

enum PhysicsMode
{
    PHYSICS_NORMAL = 0,
    PHYSICS_BHOP,
    PHYSICS_SURF,
    PHYSICS_PARKOUR
};

//====================================================
// VECTOR2
//====================================================

struct PhysicsVector2
{
    float x;
    float y;
};

//====================================================
// PLAYER BODY
//====================================================

struct PhysicsBody
{
    PhysicsVector2 position;
    PhysicsVector2 velocity;
    PhysicsVector2 acceleration;

    bool grounded;
    bool jumping;

    float gravity;
    float friction;
    float airControl;
    float maxSpeed;
    float jumpForce;
};

//====================================================
// PHYSICS MANAGER
//====================================================

class PhysicsManager
{

public:

    static bool begin();

    static void update(float deltaTime);

    static void reset();

    static void setMode(PhysicsMode mode);

    static PhysicsMode mode();

    static void setGravity(float gravity);

    static void setFriction(float friction);

    static void setAirControl(float control);

    static void setMaxSpeed(float speed);

    static void setJumpForce(float force);

    static void moveLeft();

    static void moveRight();

    static void stop();

    static void jump();

    static void land();

    static void applyForce(float x,float y);

    static float speed();

    static PhysicsVector2 position();

    static PhysicsVector2 velocity();

    static PhysicsBody& player();

private:

    static void applyGravity(float dt);

    static void applyFriction(float dt);

    static void integrate(float dt);

    static void clampSpeed();

private:

    static bool initialized;

    static PhysicsMode currentMode;

    static PhysicsBody body;

};

#endif
//====================================================
// LAND
//====================================================

void PhysicsManager::land()
{
    body.grounded = true;

    body.jumping = false;

    body.velocity.y = 0.0f;
}

//====================================================
// APPLY FORCE
//====================================================

void PhysicsManager::applyForce(
    float x,
    float y
)
{
    body.velocity.x += x;
    body.velocity.y += y;
}

//====================================================
// APPLY GRAVITY
//====================================================

void PhysicsManager::applyGravity(float dt)
{
    if(body.grounded)
        return;

    body.velocity.y += body.gravity * dt;
}

//====================================================
// APPLY FRICTION
//====================================================

void PhysicsManager::applyFriction(float dt)
{
    if(!body.grounded)
        return;

    float amount = body.friction * dt;

    if(body.velocity.x > 0.0f)
    {
        body.velocity.x -= amount;

        if(body.velocity.x < 0.0f)
            body.velocity.x = 0.0f;
    }
    else if(body.velocity.x < 0.0f)
    {
        body.velocity.x += amount;

        if(body.velocity.x > 0.0f)
            body.velocity.x = 0.0f;
    }
}

//====================================================
// INTEGRATE
//====================================================

void PhysicsManager::integrate(float dt)
{
    body.position.x += body.velocity.x * dt;

    body.position.y += body.velocity.y * dt;

    body.velocity.x += body.acceleration.x * dt;

    body.velocity.y += body.acceleration.y * dt;
}

//====================================================
// CLAMP SPEED
//====================================================

void PhysicsManager::clampSpeed()
{
    if(body.velocity.x > body.maxSpeed)
        body.velocity.x = body.maxSpeed;

    if(body.velocity.x < -body.maxSpeed)
        body.velocity.x = -body.maxSpeed;
}

//====================================================
// SETTERS
//====================================================

void PhysicsManager::setGravity(float gravity)
{
    body.gravity = gravity;
}

void PhysicsManager::setFriction(float friction)
{
    body.friction = friction;
}

void PhysicsManager::setAirControl(float control)
{
    body.airControl = control;
}

void PhysicsManager::setMaxSpeed(float speed)
{
    body.maxSpeed = speed;
}

void PhysicsManager::setJumpForce(float force)
{
    body.jumpForce = force;
}

//====================================================
// GETTERS
//====================================================

float PhysicsManager::speed()
{
    return sqrt(
        body.velocity.x * body.velocity.x +
        body.velocity.y * body.velocity.y
    );
}

PhysicsVector2 PhysicsManager::position()
{
    return body.position;
}

PhysicsVector2 PhysicsManager::velocity()
{
    return body.velocity;
}

PhysicsBody& PhysicsManager::player()
{
    return body;
}
