bool StorageManager::exists(const String& path)
{
    if (!initialized)
        return false;

    String fixed = normalizePath(path);

    return SD.exists(fixed);
}


bool StorageManager::isFile(const String& path)
{
    if (!initialized)
        return false;

    String fixed = normalizePath(path);

    File file = SD.open(fixed);

    if (!file)
        return false;


    bool result = !file.isDirectory();

    file.close();

    return result;
}


bool StorageManager::isDirectory(const String& path)
{
    if (!initialized)
        return false;

    String fixed = normalizePath(path);

    File file = SD.open(fixed);

    if (!file)
