static uint8_t brightness = BRIGHTNESS_DEFAULT;

static uint8_t volume = 100;



//---------------- Initialization ----------------


void initSettings()
{
    loadSettings();

    applySettings();
}



//---------------- Load ----------------


void loadSettings()
{
    EEPROM.get(
        0,
        brightness
    );


    EEPROM.get(
        1,
        volume
    );



    if(brightness == 0 ||
       brightness > 255)
    {
        brightness =
            BRIGHTNESS_DEFAULT;
    }



    if(volume > 100)
    {
        volume = 100;
    }
}



//---------------- Save ----------------


void saveSettings()
{
    EEPROM.put(
        0,
        brightness
    );


    EEPROM.put(
        1,
        volume
    );


    EEPROM.commit();
}



//---------------- Brightness ----------------


void increaseBrightness()
{
    if(brightness < BRIGHTNESS_HIGH)
    {
        brightness += 10;
    }


    applySettings();
}



void decreaseBrightness()
{
    if(brightness > BRIGHTNESS_LOW)
    {
        brightness -= 10;
    }


    applySettings();
}



void setBrightness(
    uint8_t value
)
{
    brightness =
        constrain(
            value,
            BRIGHTNESS_LOW,
            BRIGHTNESS_HIGH
        );


    applySettings();
}



//---------------- Volume ----------------


void increaseVolume()
{
    if(volume < 100)
        volume += 5;
}



void decreaseVolume()
{
    if(volume > 0)
        volume -= 5;
}



void setVolume(
    uint8_t value
)
{
    volume =
        constrain(
            value,
            0,
            100
        );
}



//---------------- Apply ----------------


void applySettings()
{
    setBacklight(
        brightness
    );
}



//---------------- Reset ----------------


void resetSettings()
{
    brightness =
        BRIGHTNESS_DEFAULT;


    volume = 100;


    saveSettings();


    applySettings();
}



