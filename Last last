void initMenu()
{
    currentState = STATE_MENU;

    currentGameIndex = 0;

    currentPDFIndex = 0;

    stateChangeTime = millis();
}



//---------------- Main Update ----------------

void updateMenu()
{
    char key =
        getKey();


    if(key == '\0')
        return;


    stateChangeTime =
        millis();



    switch(currentState)
    {

        case STATE_MENU:

            handleMainMenu();

            break;



        case STATE_GAME_LIST:

            handleGameMenu();

            break;



        case STATE_SETTINGS:

            handleSettingsMenu();

            break;



        case STATE_ABOUT:

            handleAboutMenu();

            break;



        case STATE_PDF_LIST:

            handlePDFMenu();

            break;



        default:

            break;
    }
}



//---------------- Main Menu ----------------

void handleMainMenu()
{
    char key =
        getLastKey();


    if(key == '1')
    {
        currentState =
            STATE_GAME_LIST;

        showGameList();
    }


    else if(key == '2')
    {
        currentState =
            STATE_SETTINGS;

        showSettings();
    }


    else if(key == '3')
    {
        currentState =
            STATE_ABOUT;

        showAbout();
    }


    else if(key == '4')
    {
        currentState =
            STATE_PDF_LIST;

        showPDFList();
    }


    clearLastKey();
}



//---------------- Game Menu ----------------

void handleGameMenu()
{
    char key =
        getLastKey();


    if(key == '2')
    {
        nextGame();
    }


    else if(key == '8')
    {
        previousGame();
    }


    else if(key == '6')
    {
        selectGame();
    }


    else if(key == '*')
    {
        returnToMenu();
    }


    clearLastKey();
}



//---------------- Settings ----------------

void handleSettingsMenu()
{
    char key =
        getLastKey();



    if(key == '5')
    {
        settings.brightness =
            BRIGHTNESS_HIGH;

        setBacklight(
            settings.brightness
        );
    }



    else if(key == '4')
    {
        settings.brightness =
            BRIGHTNESS_LOW;

        setBacklight(
            settings.brightness
        );
    }



    else if(key == '0')
    {
        saveSettings();

        returnToMenu();
    }


    clearLastKey();
}



//---------------- About ----------------

void handleAboutMenu()
{
    if(getLastKey() == '0')
    {
        returnToMenu();
    }


    clearLastKey();
}



//---------------- PDF Menu ----------------

void handlePDFMenu()
{
    char key =
        getLastKey();



    if(key == '2')
    {
        if(currentPDFIndex < pdfCount - 1)
            currentPDFIndex++;


        showPDFList();
    }



    else if(key == '8')
    {
        if(currentPDFIndex > 0)
            currentPDFIndex--;


        showPDFList();
    }



    else if(key == '6')
    {
        openPDFReader();
    }



    else if(key == '*')
    {
        returnToMenu();
    }


    clearLastKey();
}



//---------------- Navigation ----------------

void nextGame()
{
    if(currentGameIndex < gameCount - 1)
        currentGameIndex++;


    showGameList();
}



void previousGame()
{
    if(currentGameIndex > 0)
        currentGameIndex--;


    showGameList();
}



void selectGame()
{
    currentState =
        STATE_PLAYING;


    currentEngine =
        (GameEngine)
        gameFiles[currentGameIndex].type;
}



void openPDFReader()
{
    currentState =
        STATE_PDF_READER;


    showPDFReader();
}



void returnToMenu()
{
    currentState =
        STATE_MENU;


    showMainMenu();
}
