//====================================================
// BEGIN
//====================================================

void SearchEngine::begin()
{
    clear();
}


//====================================================
// CLEAR
//====================================================

void SearchEngine::clear()
{
    searchText = "";

    lastResult = -1;

    resultAmount = 0;
}


//====================================================
// ADD CHARACTER
//====================================================

void SearchEngine::addCharacter(char c)
{
    if (searchText.length() >= 32)
        return;


    searchText += c;


    updateResults();
}


//====================================================
// REMOVE CHARACTER
//====================================================

void SearchEngine::removeCharacter()
{
    if (searchText.length() == 0)
        return;


    searchText.remove(searchText.length() - 1);


    updateResults();
}
//====================================================
// QUERY
//====================================================

String SearchEngine::query()
{
    return searchText;
}


//====================================================
// SEARCH
//====================================================

int SearchEngine::search()
{
    if (resultAmount == 0)
        return -1;


    lastResult = 0;


    return resultIndexes[lastResult];
}


//====================================================
// SEARCH NEXT
//====================================================

int SearchEngine::searchNext()
{
    if (resultAmount == 0)
        return -1;


    lastResult++;


    if (lastResult >= resultAmount)
        lastResult = 0;


    return resultIndexes[lastResult];
}


//====================================================
// RESULT CHECK
//====================================================

bool SearchEngine::hasResult()
{
    return resultAmount > 0;
}


//====================================================
// RESULT COUNT
//====================================================

uint32_t SearchEngine::resultCount()
{
    return resultAmount;
}


//====================================================
// RESULT GET
//====================================================

IndexedFile SearchEngine::result(uint32_t index)
{
    if (index >= resultAmount)
    {
        return FileIndex::get(999999);
    }


    return FileIndex::get(resultIndexes[index]);
}
//====================================================
// UPDATE RESULTS
//====================================================

void SearchEngine::updateResults()
{
    resultAmount = 0;

    lastResult = -1;


    String text = searchText;

    text.toLowerCase();


    if (text.length() == 0)
        return;



    uint32_t total = FileIndex::count();


    for (uint32_t i = 0; i < total; i++)
    {
        IndexedFile file = FileIndex::get(i);


        if (compareText(file.name, text))
        {
            if (resultAmount < 128)
            {
                resultIndexes[resultAmount] = i;

                resultAmount++;
            }
        }
    }
}


//====================================================
// TEXT COMPARE
//====================================================

bool SearchEngine::compareText(const String& source,
                               const String& target)
{
    String value = source;


    value.toLowerCase();


    return value.indexOf(target) >= 0;
}
