#include "animation_manager.h"

//====================================================
//
//====================================================
// STATIC DEFINITIONS
//====================================================

bool AnimationManager::initialized = false;

KnifeType AnimationManager::currentKnife =
KNIFE_CLASSIC;

AnimationState AnimationManager::state;

AnimationFrame
AnimationManager::frames[32];

//====================================================
// BEGIN
//====================================================

bool AnimationManager::begin()
{
    if(initialized)
        return true;

    reset();

    initialized = true;

    return true;
}

//====================================================
// RESET
//====================================================

void AnimationManager::reset()
{
    state.type = ANIMATION_IDLE;

    state.frame = 0;

    state.totalFrames = 0;

    state.playing = false;

    state.loop = true;

    state.timer = millis();

    currentKnife = KNIFE_CLASSIC;
}

//====================================================
// UPDATE
//====================================================

void AnimationManager::update()
{
    if(!initialized)
        return;

    if(!state.playing)
        return;

    updateFrame();
}

//====================================================
// PLAY
//====================================================

void AnimationManager::play(
    AnimationType type
)
{
    loadAnimation(type);

    state.type = type;

    state.frame = 0;

    state.playing = true;

    state.timer = millis();
}

//====================================================
// STOP
//====================================================

void AnimationManager::stop()
{
    state.playing = false;

    state.frame = 0;
}

//====================================================
// PLAYING
//====================================================

bool AnimationManager::playing()
{
    return state.playing;
}

//====================================================
// CURRENT
//====================================================

AnimationType
AnimationManager::current()
{
    return state.type;
}

//====================================================
// SET KNIFE
//====================================================

void AnimationManager::setKnife(
    KnifeType knife
)
{
    currentKnife = knife;
}

//====================================================
// GET KNIFE
//====================================================

KnifeType
AnimationManager::knife()
{
    return currentKnife;
}
//====================================================
// UPDATE FRAME
//====================================================

void AnimationManager::updateFrame()
{
    if(state.totalFrames == 0)
        return;

    uint32_t now = millis();

    if(now - state.timer <
       frames[state.frame].duration)
    {
        return;
    }

    state.timer = now;

    state.frame++;

    if(state.frame >= state.totalFrames)
    {
        if(state.loop)
        {
            state.frame = 0;
        }
        else
        {
            state.frame = state.totalFrames - 1;

            state.playing = false;
        }
    }
}

//====================================================
// LOAD ANIMATION
//====================================================

void AnimationManager::loadAnimation(
    AnimationType type
)
{
    memset(
        frames,
        0,
        sizeof(frames)
    );

    state.loop = false;

    switch(type)
    {

        //------------------------------------------------
        // IDLE
        //------------------------------------------------

        case ANIMATION_IDLE:

            state.totalFrames = 1;

            state.loop = true;

            frames[0] =
            {
                0,
                0,
                0,
                100
            };

            break;

        //------------------------------------------------
        // DRAW
        //------------------------------------------------

        case ANIMATION_DRAW:

            state.totalFrames = 6;

            frames[0]={40,20,-70,35};
            frames[1]={28,16,-55,35};
            frames[2]={18,12,-35,35};
            frames[3]={10, 8,-18,35};
            frames[4]={ 4, 4, -8,35};
            frames[5]={ 0, 0,  0,35};

            break;

        //------------------------------------------------
        // INSPECT
        //------------------------------------------------

        case ANIMATION_INSPECT:

            state.totalFrames = 10;

            frames[0]={0,0,0,70};
            frames[1]={4,-3,12,70};
            frames[2]={8,-6,24,70};
            frames[3]={10,-8,36,70};
            frames[4]={8,-6,24,70};
            frames[5]={4,-3,12,70};
            frames[6]={0,0,0,70};
            frames[7]={-4,2,-10,70};
            frames[8]={0,0,0,70};
            frames[9]={0,0,0,70};

            break;

        //------------------------------------------------
        // SLASH 1
        //------------------------------------------------

        case ANIMATION_SLASH_1:

            state.totalFrames = 7;

            frames[0]={20,12,-35,20};
            frames[1]={10, 8,-20,20};
            frames[2]={ 0, 4,  0,20};
            frames[3]={-8, 0, 28,20};
            frames[4]={-2, 2, 14,20};
            frames[5]={ 0, 0,  0,20};
            frames[6]={ 0, 0,  0,40};

            break;
        //------------------------------------------------
        // SLASH 2
        //------------------------------------------------

        case ANIMATION_SLASH_2:

            state.totalFrames = 7;

            frames[0]={-12,10, 28,20};
            frames[1]={ -6, 6, 14,20};
            frames[2]={  2, 2,  0,20};
            frames[3]={ 12,-2,-24,20};
            frames[4]={  6, 0,-10,20};
            frames[5]={  0, 0,  0,20};
            frames[6]={  0, 0,  0,40};

            break;

        //------------------------------------------------
        // STAB
        //------------------------------------------------

        case ANIMATION_STAB:

            state.totalFrames = 8;

            frames[0]={ 12,10,-15,18};
            frames[1]={ 18, 8,-10,18};
            frames[2]={ 28, 6, -5,18};
            frames[3]={ 42, 4,  0,18};
            frames[4]={ 26, 5, -3,18};
            frames[5]={ 14, 7, -8,18};
            frames[6]={  4, 2, -2,18};
            frames[7]={  0, 0,  0,35};

            break;

        //------------------------------------------------
        // DEFAULT
        //------------------------------------------------

        default:

            state.totalFrames = 1;

            state.loop = true;

            frames[0] =
            {
                0,
                0,
                0,
                100
            };

            break;
    }
}

//====================================================
// CURRENT FRAME
//====================================================

const AnimationFrame&
AnimationManager::frame()
{
    return frames[state.frame];
}
