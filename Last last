    return StorageManager::exists(path);
}


//====================================================
// SAVE COUNT
//====================================================

uint32_t SaveManager::count(const String& game)
{
    uint32_t amount = 0;


    String folder = buildFolder(game);


    File directory = StorageManager::openFile(folder);


    if (!directory)
        return 0;


    while (true)
    {
        File entry = directory.openNextFile();


        if (!entry)
            break;


        if (!entry.isDirectory())
        {
            amount++;
        }


        entry.close();
    }


    directory.close();


    return amount;
}


