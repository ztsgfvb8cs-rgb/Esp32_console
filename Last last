#include "rtc_manager.h"


//====================================================
// STATIC DEFINITIONS
//====================================================

RTC_DS1307 RTCManager::rtc;

bool RTCManager::initialized = false;


//====================================================
// BEGIN
//====================================================

bool RTCManager::begin()
{
    if (initialized)
        return true;


    Wire.begin();


    if (!rtc.begin())
        return false;


    if (!rtc.isrunning())
    {
        rtc.adjust(
            DateTime(
                F(__DATE__),
                F(__TIME__)
            )
        );
    }


    initialized = true;


    return true;
}


//====================================================
// SET TIME
//====================================================

void RTCManager::setTime(uint8_t hour,
                         uint8_t minute,
                         uint8_t second,
                         uint8_t day,
                         uint8_t month,
                         uint16_t year)
{
    if (!initialized)
        return;


    rtc.adjust(
        DateTime(
            year,
            month,
            day,
            hour,
            minute,
            second
        )
    );
}
//====================================================
// TIME GETTERS
//====================================================

uint8_t RTCManager::hour()
{
    return rtc.now().hour();
}


uint8_t RTCManager::minute()
{
    return rtc.now().minute();
}


uint8_t RTCManager::second()
{
    return rtc.now().second();
}


//====================================================
// DATE GETTERS
//====================================================

uint8_t RTCManager::day()
{
    return rtc.now().day();
}


uint8_t RTCManager::month()
{
    return rtc.now().month();
}


uint16_t RTCManager::year()
{
    return rtc.now().year();
}


//====================================================
// STRING FORMAT
//====================================================

String RTCManager::getTimeString()
{
    DateTime now = rtc.now();


    char buffer[12];


    sprintf(
        buffer,
        "%02d:%02d:%02d",
        now.hour(),
        now.minute(),
        now.second()
    );


    return String(buffer);
}


String RTCManager::getDateString()
{
    DateTime now = rtc.now();


    char buffer[12];


    sprintf(
        buffer,
        "%02d/%02d/%04d",
        now.day(),
        now.month(),
        now.year()
    );


    return String(buffer);
}


//====================================================
// STATUS
//====================================================

bool RTCManager::available()
{
    return initialized;
}
