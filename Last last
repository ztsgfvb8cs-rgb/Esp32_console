static File pdfFile;

static bool pdfActive = false;

static uint16_t currentPage = 0;

static uint16_t pageCount = 0;

static String loadedFile;



//---------------- Initialization ----------------


void initPDFEngine()
{
    pdfActive = false;

    currentPage = 0;

    pageCount = 0;

    loadedFile = "";
}



//---------------- Open PDF ----------------


bool openPDFFile(
    const char* path
)
{
    if(pdfFile)
    {
        pdfFile.close();
    }



    pdfFile =
        SD.open(path);



    if(!pdfFile)
    {
        return false;
    }



    loadedFile =
        String(path);



    pdfActive = true;



    /*
       İlk sürümde PDF analiz motoru
       için temel yapı hazırlanıyor.

       Sayfa sayısı ilerleyen modülde
       gerçek PDF katalog taraması ile
       hesaplanacak.
    */


    pageCount = 1;

    currentPage = 1;



    return true;
}



//---------------- Close PDF ----------------


void closePDFFile()
{
    if(pdfFile)
    {
        pdfFile.close();
    }



    pdfActive = false;


    currentPage = 0;


    pageCount = 0;


    loadedFile = "";
}



//---------------- Page Load ----------------


bool loadPDFPage(
    uint16_t page
)
{
    if(!pdfActive)
        return false;



    if(page == 0 || page > pageCount)
        return false;



    currentPage = page;



    return true;
}



//---------------- Information ----------------


uint16_t getPDFPageCount()
{
    return pageCount;
}



uint16_t getCurrentPDFPage()
{
    return currentPage;
}



//---------------- Rendering ----------------


void renderPDF()
{
    if(!pdfActive)
        return;



    clearScreen();



    drawText(
        "PDF VIEWER",
        80,
        20,
        TFT_CYAN,
        2
    );



    char buffer[50];



    snprintf(
        buffer,
        sizeof(buffer),
        "PAGE %d/%d",
        currentPage,
        pageCount
    );



    drawText(
        buffer,
        100,
        70,
        TFT_YELLOW,
        2
    );



    drawText(
        loadedFile.c_str(),
        10,
        140,
        TFT_WHITE,
        1
    );



    updateScreen();
}



//---------------- Update ----------------


void updatePDFEngine()
{
    if(!pdfActive)
        return;



    renderPDF();
}
