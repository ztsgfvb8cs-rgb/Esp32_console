//====================================================
// STATIC DEFINITIONS
//====================================================

XPT2046_Touchscreen TouchManager::touch(
    TOUCH_CS,
    TOUCH_IRQ
);


TouchPoint TouchManager::currentPoint =
{
    0,
    0,
    false
};


bool TouchManager::initialized = false;


int16_t TouchManager::calMinX = 200;
int16_t TouchManager::calMaxX = 3900;

int16_t TouchManager::calMinY = 200;
int16_t TouchManager::calMaxY = 3900;


//====================================================
// BEGIN
//====================================================

bool TouchManager::begin()
{
    if (initialized)
        return true;


    touch.begin();

    touch.setRotation(1);


    initialized = true;


    return true;
}


//====================================================
// UPDATE
//====================================================

void TouchManager::update()
{
    currentPoint.pressed = false;


    if (!initialized)
        return;


    if (!touch.touched())
        return;


    TS_Point point = touch.getPoint();


    currentPoint.x = map(
        point.x,
        calMinX,
        calMaxX,
        0,
        320
    );


    currentPoint.y = map(
        point.y,
        calMinY,
        calMaxY,
        0,
        240
    );


    currentPoint.pressed = true;
}
//====================================================
// TOUCH STATUS
//====================================================

bool TouchManager::touched()
{
    return currentPoint.pressed;
}


//====================================================
// TOUCH POSITION
//====================================================

