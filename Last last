//====================================================
// SPACE INFORMATION
//====================================================

uint64_t StorageManager::totalSpace()
{
    if (!initialized)
        return 0;

    uint64_t cardSize = SD.cardSize();

    return cardSize;
}


uint64_t StorageManager::usedSpace()
{
    if (!initialized)
        return 0;

    uint64_t total = SD.totalBytes();
    uint64_t free  = SD.usedBytes();

    if (total < free)
        return 0;

    return free;
}


uint64_t StorageManager::freeSpace()
{
    if (!initialized)
        return 0;

    uint64_t total = SD.totalBytes();
    uint64_t used  = SD.usedBytes();

    if (total < used)
        return 0;

    return total - used;
}
